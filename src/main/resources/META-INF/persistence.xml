<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence
                                 http://xmlns.jcp.org/xml/ns/persistence/persistence_2_1.xsd"
             version="2.1">

    <persistence-unit name="flashSalePU" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/FlashSaleDS</jta-data-source>

        <class>com.carlock.flashsale.entity.Product</class>
        <class>com.carlock.flashsale.entity.ProductVariant</class>
        <class>com.carlock.flashsale.entity.VariantPriceTier</class>
        <class>com.carlock.flashsale.entity.ProductReview</class>
        <class>com.carlock.flashsale.entity.CustomerAccount</class>
        <class>com.carlock.flashsale.entity.SaleOrder</class>
        <class>com.carlock.flashsale.entity.OrderLineItem</class>
        <class>com.carlock.flashsale.entity.InventoryReservation</class>

        <properties>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL5Dialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>

            <!-- DO NOT change to "create" or "update" — the schema is
                 managed by the SQL migration scripts below. -->
        </properties>
    </persistence-unit>
</persistence>
